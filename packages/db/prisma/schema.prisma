generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}

model Analysis {
  id           String   @id @default(cuid())
  code         String
  language     String
  complexity   String
  suggestion   String
  timeEstimate String
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
}
