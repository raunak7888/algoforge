generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

model User {
  id        String    @id @default(cuid())
  email     String?   @unique
  username  String?   @unique
  name      String?
  image     String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  analyses  Analysis[]

  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime
  ipAddress      String?
  userAgent      String?
  rotatedFromId  String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Analysis {
  id           String   @id @default(cuid())
  userId       String
  code         String
  language     String
  complexity   String?
  suggestion   String?
  timeEstimate String?
  result       Json
  shareId      String?  @unique
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([shareId])
}

model Category {
  id          String      @id
  label       String
  description String?
  iconName    String?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  algorithms  Algorithm[]

  @@index([sortOrder])
}

model Algorithm {
  id              String     @id @default(uuid())
  slug            String     @unique
  name            String
  description     String
  categoryId      String
  forgeCode       Json
  inputSchema     Json
  guardRanges     Json
  timeComplexity  String?
  spaceComplexity String?
  difficulty      Difficulty @default(beginner)
  tags            String[]   @default([])
  isPublished     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  category        Category   @relation(fields: [categoryId], references: [id])
  snapshots       Snapshot[]

  @@index([categoryId])
  @@index([slug])
  @@index([isPublished])
}

model Snapshot {
  id              String    @id @default(uuid())
  algorithmId     String
  input           Json
  steps           Json
  executionTimeMs Int
  createdAt       DateTime  @default(now())
  algorithm       Algorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)

  @@index([algorithmId, createdAt])
}